# ============ CORE ============
NODE_ENV=production
TZ=UTC

# ============ BACKEND ============
BACKEND_PORT=4000
BACKEND_HOST=0.0.0.0
JWT_SECRET=change_me_to_a_long_random_string_min_32_chars
ADMIN_USERNAME=admin
ADMIN_PASSWORD=streamvault
CORS_ORIGIN=http://localhost:3000

# ============ FRONTEND ============
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=http://localhost:4000

# ============ DATABASE ============
# SQLite (default, easiest)
DATABASE_URL=file:./data/streamvault.db
# Postgres (production)
# DATABASE_URL=postgresql://user:pass@localhost:5432/streamvault

# ============ REDIS (optional, falls back to in-memory) ============
REDIS_URL=redis://localhost:6379
USE_REDIS=true

# ============ NTFY ============
NTFY_SERVER=https://ntfy.sh
NTFY_DEFAULT_TOPIC=streamvault-alerts
NTFY_AUTH_TOKEN=

# ============ CAPTURE ENGINE ============
SCRAPER_POLL_INTERVAL_MS=2000
SCRAPER_MAX_RETRIES=10
SCRAPER_RETRY_BACKOFF_MS=5000
SCRAPER_MAX_CONCURRENT_STREAMS=50

# ============ EXPORTS ============
EXPORT_INTERVAL_HOURS=6
EXPORT_DIR=./exports
EXPORT_RETENTION_DAYS=30
EXPORT_COMPRESS=true

# ============ ALERTS ============
ALERT_DEDUPE_WINDOW_SEC=60
ALERT_RATE_LIMIT_PER_MIN=30

# ============ LOGGING ============
LOG_LEVEL=info
LOG_PRETTY=false
