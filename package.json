{
  "name": "streamvault",
  "private": true,
  "workspaces": [
    "frontend",
    "backend",
    "shared"
  ],
  "scripts": {
    "frontend": "npm --workspace frontend run dev",
    "backend": "npm --workspace backend run dev",
    "build:shared": "npm --workspace shared run build --if-present",
    "build:backend": "npm --workspace backend run build",
    "build:frontend": "npm --workspace frontend run build",
    "build": "npm run build:shared && npm run build:backend && npm run build:frontend",
    "start": "npm --workspace backend run start"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
